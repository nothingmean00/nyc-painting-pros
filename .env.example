# Estimate form delivery (POST /api/estimate)
# Copy this file to .env.local and fill in real values.

# Get a free key at https://resend.com (required to actually send lead emails).
RESEND_API_KEY=

# Inbox that should receive estimate requests. Defaults to site.email if unset.
ESTIMATE_TO_EMAIL=hello@nycpaintingpros.com

# Verified Resend sender. For quick testing you can use onboarding@resend.dev;
# for production, verify your domain in Resend and use e.g. estimates@nycpaintingpros.com
ESTIMATE_FROM_EMAIL=onboarding@resend.dev
